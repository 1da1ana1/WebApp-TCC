generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique
  password    String        // Mantido para o nosso login provisório local
  typeUser    String        // "STUDENT", "TEACHER", "COORDINATOR"
  keywords      UserKeyword[]
  student       Student?
  teacher       Teacher?
  logs          ActivityLog[]
  notifications Notification[]
}

model Keyword {
  id    Int           @id @default(autoincrement())
  name  String        @unique
  users UserKeyword[]
}

model UserKeyword {
  user      User    @relation(fields: [userId], references: [id])
  userId    Int
  keyword   Keyword @relation(fields: [keywordId], references: [id])
  keywordId Int
  @@id([userId, keywordId])
}

model Student {
  id            Int             @id @default(autoincrement())
  ra            String          @unique
  userId        Int             @unique
  user          User            @relation(fields: [userId], references: [id])
  requests      Request[]
  orientations  Orientation[]   @relation("StudentOrientations")
}

model Teacher {
  id               Int                 @id @default(autoincrement())
  lattesLink       String?
  isCoordinator    Boolean             @default(false)
  userId           Int                 @unique
  user             User                @relation(fields: [userId], references: [id])
  attendedRequests Request[]
  supervisorOf     Orientation[]       @relation("SupervisorOrientations")
  memberOf         OrientationMember[]
  coordinator      Coordinator?
  vacancies        Vacancy[]           
  contestations    Contestation[]      
}

model Coordinator {
  id            Int            @id @default(autoincrement())
  teacherId     Int            @unique
  teacher       Teacher        @relation(fields: [teacherId], references: [id])
  contestations Contestation[]
  vacancies     Vacancy[]
}

model Request {
  id                  Int       @id @default(autoincrement())
  sendDate            DateTime  @default(now())
  responseDate        DateTime? // Data que o professor aceitou/recusou (Histórico)
  status              String    // PENDING, ACCEPTED, REJECTED
  denialJustification String?   // Apenas se REJECTED
  student             Student   @relation(fields: [studentId], references: [id])
  studentId           Int
  teacher             Teacher?  @relation(fields: [teacherId], references: [id])
  teacherId           Int?
}

model Orientation {
  id            Int                 @id @default(autoincrement())
  status        String              // ACTIVE, COMPLETED, CANCELED
  startDate     DateTime?
  endDate       DateTime?
  semester      Semester?           @relation(fields: [semesterId], references: [id])
  semesterId    Int?
  students      Student[]           @relation("StudentOrientations")
  supervisor    Teacher?            @relation("SupervisorOrientations", fields: [supervisorId], references: [id])
  supervisorId  Int?
  members       OrientationMember[]
}

model OrientationMember {
  id            Int         @id @default(autoincrement())
  orientation   Orientation @relation(fields: [orientationId], references: [id])
  orientationId Int
  teacher       Teacher     @relation(fields: [teacherId], references: [id])
  teacherId     Int

  @@unique([orientationId, teacherId])
}

model Semester {
  id                       Int           @id @default(autoincrement())
  year                     Int
  period                   String
  isActive                 Boolean       @default(false)

  // Datas do Cronograma da Coordenação
  vacancyDefStartDate      DateTime?     // Definição de vagas
  vacancyDefEndDate        DateTime?
  themeRegStartDate        DateTime?     // Cadastro de temas
  themeRegEndDate          DateTime?
  searchStartDate          DateTime?     // Período de busca de orientadores
  searchEndDate            DateTime?
  analysisStartDate        DateTime?     // Análise de solicitações
  analysisEndDate          DateTime?
  linkConfirmStartDate     DateTime?     // Confirmação de vínculo
  linkConfirmEndDate       DateTime?
  orientationStartDate     DateTime?     // Início das orientações
  homologationDate         DateTime?     // Homologação
  closureDate              DateTime?     // Encerramento do semestre

  orientations             Orientation[]
  vacancies                Vacancy[]     
}

model Contestation {
  id                 Int         @id @default(autoincrement())
  contestationReason String
  status             String      @default("PENDING") // PENDING, RESOLVED
  resolvedAt         DateTime?   
  coordinator        Coordinator @relation(fields: [coordinatorId], references: [id])
  coordinatorId      Int
  teacher            Teacher     @relation(fields: [teacherId], references: [id]) 
  teacherId          Int
  vacancy            Vacancy?    @relation(fields: [vacancyId], references: [id]) 
  vacancyId          Int?
}

model Vacancy {
  id              Int            @id @default(autoincrement())
  quantity        Int
  isContested     Boolean        @default(false) 
  contestDeadline DateTime?      
  contestReason   String?        
  coordinator     Coordinator    @relation(fields: [coordinatorId], references: [id])
  coordinatorId   Int
  teacher         Teacher        @relation(fields: [teacherId], references: [id]) 
  teacherId       Int
  semester        Semester?      @relation(fields: [semesterId], references: [id]) 
  semesterId      Int?
  contestations   Contestation[] 
}

model ActivityLog {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  action          String    // Ex: "LOGIN", "CREATE_REQUEST", "ACCEPT_STUDENT"
  loginAt         DateTime?
  logoutAt        DateTime?
  sessionDuration Int?
  createdAt       DateTime  @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String   // NEW_REQUEST, REQUEST_RESPONSE, VACANCY_DEFINED, CONTESTATION
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?  // rota no front para "ver detalhes" (opcional)
  createdAt DateTime @default(now())

  @@index([userId, read])
}