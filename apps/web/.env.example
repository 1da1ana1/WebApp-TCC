# Copy this file to .env and adjust values for your environment.
#
# VITE_API_BASE_URL — base URL for the NestJS backend, used by services/api.js.
# - Dev (Vite proxy): keep as /api (vite.config.js forwards /api -> http://localhost:3000).
# - Same-origin prod (Nginx serves SPA + proxies /api): keep as /api.
# - Cross-origin prod (SPA on CDN / API on its own host): use the absolute URL,
#   e.g. https://api.tcc.unicamp.br
VITE_API_BASE_URL=/api
