# Copy this file to .env and adjust values for your environment.
#
# VITE_API_BASE_URL — base URL for the NestJS backend, used by services/api.js.
# - Dev (Vite proxy): keep as /api (vite.config.js forwards /api -> http://localhost:3000).
# - Same-origin prod (Nginx serves SPA + proxies /api): keep as /api.
# - Cross-origin prod (SPA on CDN / API on its own host): use the absolute URL,
#   e.g. https://api.tcc.unicamp.br
VITE_API_BASE_URL=/api

# VITE_ENABLE_DEV_LOGIN — habilita a rota /dev-login (1 clique para alternar
# entre Aluno / Professor / Coordenador usando os usuários do seed).
# - Dev local: ignorado — a rota é sempre liberada quando import.meta.env.DEV
#   é true.
# - Staging/Homologação: setar 'true' para QA conseguir trocar de papel sem
#   contas reais. Lembrar de rebuildar — vars VITE_* são inlinadas em build
#   time, não há flip runtime.
# - Produção: manter 'false' ou removido. Com a flag desligada, a rota nem
#   é registrada no bundle (ver router/index.js).
VITE_ENABLE_DEV_LOGIN=false
